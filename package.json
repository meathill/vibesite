{
  "name": "vibesite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 4000",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "format": "biome check --write",
    "format:check": "biome check",
    "lint": "biome lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:init": "wrangler d1 execute vibesite-db --file=./db/schema.sql",
    "db:seed": "wrangler d1 execute vibesite-db --file=./db/seed.sql",
    "db:migrate": "wrangler d1 migrations apply vibesite-db",
    "db:migrate:create": "wrangler d1 migrations create vibesite-db",
    "db:migrate:list": "wrangler d1 migrations list vibesite-db",
    "deploy:script": "node --experimental-strip-types scripts/deploy.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@opennextjs/cloudflare": "^1.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/postcss": "^4.3.1",
    "better-auth": "^1.6.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "^15.3.0",
    "postcss": "^8.5.15",
    "react": "^19.1.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.1.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@cloudflare/workers-types": "^4.20260621.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.20.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
