{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "vibesite",
  "compatibility_date": "2026-06-20",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "vibesite",
      "database_id": "6e2c0866-4f8a-4e72-9d0d-37a9faedb18c"
    },
    {
      "binding": "NEXT_TAG_CACHE_D1",
      "database_name": "tag-cache",
      "database_id": "5f26868d-5d24-4645-8954-a27168f6fcd6"
    }
  ],
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  },
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "vibesite"
    },
    {
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "site-cache"
    }
  ],
  "send_email": [
    {
      "name": "EMAIL",
      "allowed_destination_addresses": ["*"]
    }
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "vibesite"
    }
  ],
  "vars": {
    "ADMIN_EMAIL": "meathill@gmail.com",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY": "",
    "NEXT_PUBLIC_GA_ID": "G-28VYQDS5S0",
    "TELEGRAM_CHAT_ID": "430446503"
  }
}
